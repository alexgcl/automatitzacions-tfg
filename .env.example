############################################
# CONFIGURACIÓ GENERAL DE L’APLICACIÓ
############################################

# Clau secreta per a la integritat de cookies (Generar un Hex aleatori)
# KEY generada en https://www.browserling.com/tools/random-hex (es  poden utilitzar altres)
SECRET_KEY_BASE=omplir_amb_hex_aleatori

# URL principal de l’aplicació (frontend) - Canviar pel domini real en producció
FRONTEND_URL=http://nginx:8081
DEFAULT_LOCALE=es
FORCE_SSL=false
ENABLE_ACCOUNT_SIGNUP=false

############################################
# CONFIGURACIÓ DE BASE DE DADES (POSTGRES)
############################################

POSTGRES_HOST=postgres-chatwoot
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=omplir_contrasenya_db
RAILS_ENV=production
RAILS_MAX_THREADS=5

############################################
# CONFIGURACIÓ DE REDIS
############################################

REDIS_URL=redis://redis-chatwoot:6379
REDIS_PASSWORD=omplir_contrasenya_redis

############################################
# CONFIGURACIÓ DE CORREU SORTINT (SMTP)
############################################

MAILER_SENDER_EMAIL=teu_correu@domini.com
SMTP_DOMAIN=gmail.com
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=teu_correu@gmail.com
SMTP_PASSWORD=clau_aplicacio_gmail_vint_caracters
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer

############################################
# CONFIGURACIÓ DE CORREU ENTRANT (IMAP)
############################################

MAILER_INBOUND_EMAIL_DOMAIN=gmail.com
RAILS_INBOUND_EMAIL_SERVICE=imap
IMAP_ENABLED=true
IMAP_ADDRESS=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=teu_correu@gmail.com
IMAP_PASSWORD=clau_aplicacio_gmail_vint_caracters
IMAP_ENABLE_SSL=true
IMAP_FOLDER=[Gmail]/Todos
RAILS_INBOUND_EMAIL_PASSWORD=clau_aplicacio_gmail_vint_caracters

############################################
# CONFIGURACIÓ D’EMMAGATZEMAMENT (STORAGE)
############################################

ACTIVE_STORAGE_SERVICE=local

############################################
# CONFIGURACIÓ DE LOGS I MONITORATGE
############################################

RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
LOG_SIZE=500

############################################
# INTEGRACIONS AMB XARXES SOCIALS (OPCIONAL)
############################################

FB_VERIFY_TOKEN=
FB_APP_SECRET=
FB_APP_ID=
TWITTER_APP_ID=
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=

############################################
# CONFIGURACIÓ PER A APLICACIONS MÒBILS
############################################

IOS_APP_ID=6C953F3RX2.com.chatwoot.app

############################################
# CONFIGURACIÓ DE N8N
############################################

# Base de dades PostgreSQL per a n8n
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres-n8n
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=n8n
N8N_DB_POSTGRESDB_USER=postgres
N8N_DB_POSTGRESDB_PASSWORD=omplir_contrasenya_db_n8n

# Configuració de l'aplicació n8n
N8N_PROTOCOL=http
N8N_HOST=n8n
N8N_PORT=5678

# URL base per a l'editor i webhooks
# En producció, canviar localhost pel domini real
N8N_EDITOR_BASE_URL=http://localhost:8083
WEBHOOK_URL=http://n8n:5678/

# Zona horària
GENERIC_TIMEZONE=Europe/Madrid

EXECUTIONS_PROCESS=main
EXECUTIONS_MODE=regular