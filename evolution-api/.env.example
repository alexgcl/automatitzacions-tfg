# .env.example
############################################
# CONFIGURACIÓ GENERAL DEL SERVIDOR
############################################

# Tipus de servidor (http o https)
SERVER_TYPE=http
# Port en el qual s’executa el servidor
SERVER_PORT=8080
# URL base del servidor
SERVER_URL=http://evolution-api:8080

# Clau d’autenticació per a l’API
## API KEY generada en https://skybootstrap.com/tools/es/uuid-generator (es  poden utilitzar altres)
AUTHENTICATION_API_KEY=posa_aqui_el_teu_apikey_secret
# Mostra la clau d’autenticació a les peticions fetch d’instàncies
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# Si està actiu, permet eliminar instàncies
DEL_INSTANCE=false
# Límits per a codis QR generats
QRCODE_LIMIT=1902
# Idioma per defecte de l’aplicació
LANGUAGE=es


############################################
# CONFIGURACIÓ DEL CLIENT WHATSAPP
############################################

# Versió del client WhatsApp Web
# Pots consultar-ne l’última versió a: https://web.whatsapp.com/check-update?version=0&platform=web
CONFIG_SESSION_PHONE_VERSION=2.3000.1028326730
# Tipus de dispositiu utilitzat pel client
CONFIG_SESSION_PHONE_CLIENT=Google
# Nom del navegador o client
CONFIG_SESSION_PHONE_NAME=Chrome


############################################
# CONFIGURACIÓ DE LA BASE DE DADES
############################################

# Habilita l’ús de base de dades
DATABASE_ENABLED=true

# Tipus de proveïdor de base de dades (postgresql, mysql, etc.)
DATABASE_PROVIDER=postgresql

# URI de connexió a la base de dades
DATABASE_CONNECTION_URI=postgresql://postgres:omplir_contrasenya_db@postgres-evolution:5432/evolution

# Nom del client de connexió
DATABASE_CONNECTION_CLIENT_NAME=evolution

# Opcions per desar dades a la base de dades
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true


############################################
# INTEGRACIONS AMB PLATAFORMES D’IA
############################################

# Integració amb OpenAI
OPENAI_ENABLED=true

# Integració amb Dify
DIFY_ENABLED=true

# Integració amb Typebot
TYPEBOT_ENABLED=true
TYPEBOT_API_VERSION=latest


############################################
# INTEGRACIÓ AMB CHATWOOT
############################################

CHATWOOT_ENABLED=true
CHATWOOT_MESSAGE_READ=true
CHATWOOT_MESSAGE_DELETE=true

# Connexió a la base de dades de Chatwoot per a importacions
CHATWOOT_IMPORT_DATABASE_CONNECTION_URI=postgresql://postgres:omplir_contrasenya_chatwoot@postgres-chatwoot:5432/chatwoot_production?sslmode=disable

# Mostra missatges multimèdia com a text de substitució (si és fals, no es mostren)
CHATWOOT_IMPORT_PLACEHOLDER_MEDIA_MESSAGE=false

# Permet que el bot es mostri com a contacte actiu
CHATWOOT_BOT_CONTACT=true


############################################
# CONFIGURACIÓ DE CACHE
############################################

# Activa l’ús de Redis com a sistema de cache
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis-evolution:6379/8
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false

# Cache local (en memòria)
CACHE_LOCAL_ENABLED=false


############################################
# CONFIGURACIÓ D’EMMAGATZEMAMENT (S3)
############################################

# Activa l’ús de S3 per a emmagatzematge de fitxers
S3_ENABLED=false
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=evolution
S3_PORT=443
S3_ENDPOINT=
S3_USE_SSL=true


############################################
# CONFIGURACIÓ DE WHATSAPP BUSINESS
############################################

# Token per al Webhook de WhatsApp Business
WA_BUSINESS_TOKEN_WEBHOOK=evolution

# URL base de l’API de Facebook Graph
WA_BUSINESS_URL=https://graph.facebook.com

# Versió de l’API de WhatsApp Business
WA_BUSINESS_VERSION=v20.0

# Idioma per defecte
WA_BUSINESS_LANGUAGE=es


############################################
# TELEMETRIA
############################################

# Activa o desactiva la telemetria
TELEMETRY=false

# URL de destí per enviar dades de telemetria (si està activa)
TELEMETRY_URL=


############################################
# CONFIGURACIÓ DEL WEBSOCKET
############################################

# Habilita el canal WebSocket
WEBSOCKET_ENABLED=false

# Permet esdeveniments globals via WebSocket
WEBSOCKET_GLOBAL_EVENTS=false


############################################
# CONFIGURACIÓ D’AWS SQS (Simple Queue Service)
############################################

SQS_ENABLED=false
SQS_ACCESS_KEY_ID=
SQS_SECRET_ACCESS_KEY=
SQS_ACCOUNT_ID=
SQS_REGION=


############################################
# CONFIGURACIÓ DE RABBITMQ
############################################

# Habilita l’ús de RabbitMQ
RABBITMQ_ENABLED=false

# URI de connexió
RABBITMQ_URI=amqp://USER:PASS@rabbitmq:5672/default

# Nom de l’intercanvi (exchange)
RABBITMQ_EXCHANGE_NAME=evolution

# Esdeveniments globals i configuracions generals
RABBITMQ_GLOBAL_ENABLED=false
RABBITMQ_EVENTS_APPLICATION_STARTUP=false
RABBITMQ_EVENTS_INSTANCE_CREATE=false
RABBITMQ_EVENTS_INSTANCE_DELETE=false
RABBITMQ_EVENTS_QRCODE_UPDATED=false
RABBITMQ_EVENTS_MESSAGES_SET=false
RABBITMQ_EVENTS_MESSAGES_UPSERT=true
RABBITMQ_EVENTS_MESSAGES_EDITED=false
RABBITMQ_EVENTS_MESSAGES_UPDATE=false
RABBITMQ_EVENTS_MESSAGES_DELETE=false
RABBITMQ_EVENTS_SEND_MESSAGE=false
RABBITMQ_EVENTS_CONTACTS_SET=false
RABBITMQ_EVENTS_CONTACTS_UPSERT=false
RABBITMQ_EVENTS_CONTACTS_UPDATE=false
RABBITMQ_EVENTS_PRESENCE_UPDATE=false
RABBITMQ_EVENTS_CHATS_SET=false
RABBITMQ_EVENTS_CHATS_UPSERT=false
RABBITMQ_EVENTS_CHATS_UPDATE=false
RABBITMQ_EVENTS_CHATS_DELETE=false
RABBITMQ_EVENTS_GROUPS_UPSERT=false
RABBITMQ_EVENTS_GROUP_UPDATE=false
RABBITMQ_EVENTS_GROUP_PARTICIPANTS_UPDATE=false
RABBITMQ_EVENTS_CONNECTION_UPDATE=true
RABBITMQ_EVENTS_CALL=false
RABBITMQ_EVENTS_TYPEBOT_START=false
RABBITMQ_EVENTS_TYPEBOT_CHANGE_STATUS=false


############################################
# CONFIGURACIÓ DEL WEBHOOK
############################################

WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

# Esdeveniments disponibles per al Webhook
WEBHOOK_EVENTS_APPLICATION_STARTUP=false
WEBHOOK_EVENTS_QRCODE_UPDATED=false
WEBHOOK_EVENTS_MESSAGES_SET=false
WEBHOOK_EVENTS_MESSAGES_UPSERT=false
WEBHOOK_EVENTS_MESSAGES_EDITED=false
WEBHOOK_EVENTS_MESSAGES_UPDATE=false
WEBHOOK_EVENTS_MESSAGES_DELETE=false
WEBHOOK_EVENTS_SEND_MESSAGE=false
WEBHOOK_EVENTS_CONTACTS_SET=false
WEBHOOK_EVENTS_CONTACTS_UPSERT=false
WEBHOOK_EVENTS_CONTACTS_UPDATE=false
WEBHOOK_EVENTS_PRESENCE_UPDATE=false
WEBHOOK_EVENTS_CHATS_SET=false
WEBHOOK_EVENTS_CHATS_UPSERT=false
WEBHOOK_EVENTS_CHATS_UPDATE=false
WEBHOOK_EVENTS_CHATS_DELETE=false
WEBHOOK_EVENTS_GROUPS_UPSERT=false
WEBHOOK_EVENTS_GROUPS_UPDATE=false
WEBHOOK_EVENTS_GROUP_PARTICIPANTS_UPDATE=false
WEBHOOK_EVENTS_CONNECTION_UPDATE=false
WEBHOOK_EVENTS_LABELS_EDIT=false
WEBHOOK_EVENTS_LABELS_ASSOCIATION=false
WEBHOOK_EVENTS_CALL=false
WEBHOOK_EVENTS_TYPEBOT_START=false
WEBHOOK_EVENTS_TYPEBOT_CHANGE_STATUS=false
WEBHOOK_EVENTS_ERRORS=false
WEBHOOK_EVENTS_ERRORS_WEBHOOK=


############################################
# CONFIGURACIÓ DEL PROVEÏDOR (PROVIDER)
############################################

PROVIDER_ENABLED=false
PROVIDER_HOST=127.0.0.1
PROVIDER_PORT=5656
PROVIDER_PREFIX=evolution
